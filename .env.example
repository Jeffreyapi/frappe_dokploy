# =============================================================================
#  frappe_dokploy — .env.example
#  Copier ce fichier en .env et renseigner toutes les valeurs.
#  Ne jamais committer le fichier .env.
# =============================================================================

# ── Image Docker ──────────────────────────────────────────────────────────────
# Nom complet de l'image (registry/org/nom)
IMAGE_NAME=ghcr.io/jeffreyapi/frappe
# Tag de l'image à déployer
APP_VERSION=latest
# Politique de pull : always | never | if_not_present
PULL_POLICY=always

# ── Site Frappe ───────────────────────────────────────────────────────────────
# Nom de domaine du site (ex: monapp.example.com)
SITE_NAME=
# Mot de passe administrateur Frappe
ADMIN_PASSWORD=
# Header pour résoudre le site depuis le nom d'hôte (laisser vide = $host)
FRAPPE_SITE_NAME_HEADER=

# ── Base de données ───────────────────────────────────────────────────────────
# Mot de passe root MariaDB
DB_ROOT_PASSWORD=
# Hôte de la base de données (db = conteneur interne, ou IP/hostname externe)
DB_HOST=db
DB_PORT=3306
# 1 = inclure le conteneur MariaDB dans la stack, 0 = base de données externe
ENABLE_DB=1

# ── Environnement ─────────────────────────────────────────────────────────────
# dev ou prod (affecte la gestion de l'encryption_key au restore)
ENVIRONMENT=dev

# ── Applications Frappe ───────────────────────────────────────────────────────
# Apps à installer sur le site au premier démarrage (séparées par des virgules)
# Exemple : APPS=erpnext,mon_app
APPS=
# Apps à cibler lors d'un update/build ciblé (laisser vide = toutes)
UPDATE_APPS=

# ── Comportement du site-manager ─────────────────────────────────────────────
# 1 = lancer le site-manager au démarrage, 0 = ne pas lancer
SITE_MANAGER_RUN=1
# 1 = restaurer depuis S3 au lieu de créer/mettre à jour
RESTORE=0
# Patterns de fixtures à neutraliser (inline, virgules). Préférer skip_fixtures.list
SKIP_FIXTURES=
# Mode de neutralisation des fixtures : rm (suppression) | empty (écraser avec [])
NEUTRALIZE_MODE=rm

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_CACHE=redis-cache:6379
REDIS_QUEUE=redis-queue:6379
SOCKETIO_PORT=9000

# ── Frontend ──────────────────────────────────────────────────────────────────
# Port exposé localement pour accéder à l'interface
FRONTEND_PORT=8080
# Taille max des uploads (nginx)
CLIENT_MAX_BODY_SIZE=50m
# Timeout proxy nginx
PROXY_READ_TIMEOUT=120

# ── Backup S3 ─────────────────────────────────────────────────────────────────
# 1 = activer les backups automatiques vers S3
S3_BACKUP_ENABLED=0
# Nom du bucket S3
S3_BACKUP_BUCKET=
# Clé d'accès S3
S3_BACKUP_ACCESS_KEY=
# Clé secrète S3
S3_BACKUP_SECRET_KEY=
# Région S3 (pour AWS, inutile pour MinIO)
S3_BACKUP_REGION=us-east-1
# Endpoint S3 compatible (laisser vide pour AWS, renseigner pour MinIO/autre)
S3_ENDPOINT_URL=

# ── Build local (docker-compose.build.yml uniquement) ────────────────────────
# Token GitHub pour cloner les apps privées lors du build local
# GH_PAT=
# Branche Frappe à utiliser lors du build local
FRAPPE_VERSION=version-15
