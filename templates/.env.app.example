# =============================================================================
#  Template : .env.example — à placer à la RACINE du repo app.
#
#  Instructions :
#    1. Copier ce fichier en .env.example dans le repo app
#    2. Remplacer MY_APP par le nom de l'application
#    3. Renseigner les valeurs projet-spécifiques dans les commentaires
#    4. Ne jamais committer le fichier .env (secrets)
# =============================================================================

# ── Image Docker ──────────────────────────────────────────────────────────────
# Nom de l'image spécifique à ce projet
# Exemples : ghcr.io/jeffreyapi/pharmtek | ghcr.io/jeffreyapi/talents30
IMAGE_NAME=ghcr.io/jeffreyapi/MY_APP
# Tag à déployer (latest, ou un tag précis ex: main-abc1234 pour la prod)
APP_VERSION=latest
# Politique de pull : always | never | if_not_present
PULL_POLICY=always

# ── Site Frappe ───────────────────────────────────────────────────────────────
# Nom de domaine du site (doit correspondre à la règle Traefik dans docker-compose.yml)
SITE_NAME=MY_APP.example.com
# Mot de passe administrateur Frappe
ADMIN_PASSWORD=
# Header pour résoudre le site depuis le nom d'hôte (laisser vide = $host)
FRAPPE_SITE_NAME_HEADER=

# ── Base de données ───────────────────────────────────────────────────────────
# Mot de passe root MariaDB
DB_ROOT_PASSWORD=
# Hôte de la base de données (db = conteneur interne)
DB_HOST=db
DB_PORT=3306
# 1 = inclure le conteneur MariaDB dans la stack, 0 = base de données externe
ENABLE_DB=1

# ── Environnement ─────────────────────────────────────────────────────────────
# dev ou prod (affecte la gestion de l'encryption_key lors du restore)
ENVIRONMENT=dev

# ── Applications Frappe ───────────────────────────────────────────────────────
# Apps à installer sur le site au premier démarrage (virgules)
# Exemple sans ERPNext   : APPS=mon_app
# Exemple avec ERPNext   : APPS=erpnext,mon_app
APPS=MY_APP
# Apps à cibler lors d'un update ciblé (laisser vide = toutes les apps)
UPDATE_APPS=

# ── Comportement du site-manager ─────────────────────────────────────────────
# 1 = lancer le site-manager au démarrage (create/restore/update automatique)
SITE_MANAGER_RUN=1
# 1 = restaurer depuis S3 au lieu de créer ou mettre à jour
RESTORE=0
# Patterns de fixtures à neutraliser (inline, virgules). Préférer skip_fixtures.list
SKIP_FIXTURES=
# Mode de neutralisation : rm (suppression) | empty (écraser avec [])
NEUTRALIZE_MODE=rm

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_CACHE=redis-cache:6379
REDIS_QUEUE=redis-queue:6379
SOCKETIO_PORT=9000

# ── Frontend ──────────────────────────────────────────────────────────────────
# Port exposé localement (utile en dev pour accéder sans Traefik)
FRONTEND_PORT=8080
# Taille max des uploads (nginx)
CLIENT_MAX_BODY_SIZE=50m
# Timeout proxy nginx (secondes)
PROXY_READ_TIMEOUT=120

# ── Backup S3 ─────────────────────────────────────────────────────────────────
# Nom du bucket S3 (laisser vide pour désactiver le backup S3)
S3_BACKUP_BUCKET=
# Clé d'accès S3
S3_BACKUP_ACCESS_KEY=
# Clé secrète S3
S3_BACKUP_SECRET_KEY=
# Endpoint S3-compatible (laisser vide pour AWS, renseigner pour MinIO/autre)
S3_ENDPOINT_URL=

# ── Build local (avec docker-compose.build.yml uniquement) ───────────────────
# Token GitHub pour cloner les apps privées lors du build local
# Passer en variable d'environnement plutôt que dans ce fichier :
#   export GH_PAT=ghp_xxx && make build
# GH_PAT=
# Branche Frappe à utiliser lors du build local
FRAPPE_VERSION=version-15
